# Copy this file to `.env` and fill in your keys. `.env` is gitignored.

# Free ABR web-services GUID for ABN Lookup validation.
# Register (2 minutes, free): https://abr.business.gov.au/Tools/WebServices
# Without it the pipeline still runs — candidates just skip ABN validation.
ABR_GUID=

# Deferred / optional paid step. Leave blank for the free pilot.
# Also requires flipping ENABLED=true in lib/places.js.
GOOGLE_PLACES_API_KEY=
